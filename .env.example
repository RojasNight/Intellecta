# Public Supabase variables for the Vite frontend.
# Copy this file to .env.local for local development.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional compatibility variables for Vercel/Supabase Integration.
# Prefer VITE_* for this Vite project when setting variables manually.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key must never be exposed to frontend/Vercel client-side env.
