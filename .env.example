# If Supabase was connected through Vercel Integration,
# check Vercel Project Settings → Environment Variables.
# For Vite, client variables must start with VITE_.

VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Альтернативный вариант, если Vercel Supabase Integration уже создала NEXT_PUBLIC_* переменные.
# Проект поддерживает их через envPrefix в vite.config.ts.
# NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key
