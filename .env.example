# Public Supabase variables for the Vite frontend.
# Copy this file to .env.local for local development.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional compatibility variables for Vercel/Supabase Integration.
# Prefer VITE_* for this Vite project when setting variables manually.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only variables for Vercel Serverless Functions.
# Never prefix these variables with VITE_ or NEXT_PUBLIC_.
# Never read them from frontend code.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Stage 17: OpenRouter server-side AI analysis.
# Frontend must never receive these values.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/free
OPENROUTER_EMBEDDING_MODEL=

# Optional Vercel/OpenRouter referer header.
APP_URL=
